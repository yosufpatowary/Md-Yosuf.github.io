<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Md. Yosuf — Economics Graduate & Development Economist</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet"/>
<style>
  :root {
    --cream: #F5F0E8;
    --warm-white: #FAFAF7;
    --charcoal: #1A1A18;
    --dark: #2C2C28;
    --accent: #B5622A;
    --accent-light: #D4845A;
    --muted: #7A7A6E;
    --border: #E0DAD0;
    --light-gray: #EEEBE4;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--warm-white);
    color: var(--charcoal);
    overflow-x: hidden;
  }


  /* PHOTO STYLES */
  .hero-photo-wrap {
    position: relative;
    width: 320px; height: 380px;
    flex-shrink: 0;
  }
  .hero-photo-frame {
    width: 100%; height: 100%;
    position: relative; z-index: 2;
    overflow: hidden;
    border: 3px solid var(--border);
  }
  .hero-photo-frame img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: top center;
    display: block;
    filter: grayscale(8%) contrast(1.02);
    transition: transform 0.5s ease;
  }
  .hero-photo-frame:hover img { transform: scale(1.04); }
  .hero-photo-bg {
    position: absolute;
    top: 16px; left: 16px;
    width: 100%; height: 100%;
    background: var(--accent);
    z-index: 1;
  }
  .hero-photo-tag {
    position: absolute; bottom: -1rem; right: -1rem;
    z-index: 3;
    background: var(--charcoal); color: white;
    padding: 0.6rem 1.2rem;
    font-size: 0.68rem; letter-spacing: 0.12em;
    text-transform: uppercase; font-weight: 600;
  }
  .hero-stats-row {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 1rem; margin-top: 2.5rem;
    max-width: 340px;
  }
  .hero-stat-box {
    background: white; border: 1px solid var(--border);
    padding: 1rem 1.2rem;
  }
  .hero-stat-number {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem; font-weight: 900;
    color: var(--charcoal); line-height: 1;
  }
  .hero-stat-label {
    font-size: 0.65rem; color: var(--muted);
    text-transform: uppercase; letter-spacing: 0.08em;
    margin-top: 0.3rem; line-height: 1.4;
  }
  /* MOBILE PHOTO — shows above text on small screens */
  .hero-photo-mobile {
    display: none;
    width: 120px; height: 120px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--accent);
    flex-shrink: 0;
    margin-bottom: 1.5rem;
    box-shadow: 4px 4px 0 var(--accent);
  }
  .hero-photo-mobile img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: top center;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.2rem 4rem;
    background: rgba(250,250,247,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem; font-weight: 700;
    color: var(--charcoal); text-decoration: none;
    letter-spacing: -0.02em;
  }
  .nav-logo span { color: var(--accent); }
  .nav-links { display: flex; gap: 1.5rem; list-style: none; flex-wrap: wrap; }
  .nav-links a {
    font-size: 0.82rem; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--muted); text-decoration: none; font-weight: 500;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--accent); }

  /* HAMBURGER BUTTON */
  .nav-toggle {
    display: none;
    flex-direction: column; gap: 5px;
    cursor: pointer; padding: 4px;
    background: none; border: none;
    z-index: 200;
  }
  .nav-toggle span {
    display: block; width: 24px; height: 2px;
    background: var(--charcoal);
    transition: all 0.3s ease;
    transform-origin: center;
  }
  .nav-toggle.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .nav-toggle.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* MOBILE MENU OVERLAY */
  .mobile-menu {
    display: none;
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background: var(--warm-white);
    z-index: 150;
    flex-direction: column;
    opacity: 0; pointer-events: none;
    transition: opacity 0.35s ease;
    overflow-y: auto;
  }
  .mobile-menu.open {
    opacity: 1; pointer-events: all;
  }
  .mobile-menu-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.4rem 1.8rem;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .mobile-menu-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem; font-weight: 700;
    color: var(--charcoal); letter-spacing: -0.02em;
  }
  .mobile-menu-logo span { color: var(--accent); }
  .mobile-close {
    background: none; border: 1px solid var(--border);
    width: 36px; height: 36px; border-radius: 2px;
    font-size: 1rem; color: var(--muted);
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: all 0.2s;
  }
  .mobile-close:hover { background: var(--charcoal); color: white; border-color: var(--charcoal); }
  .mobile-nav {
    display: flex; flex-direction: column;
    padding: 2rem 1.8rem; gap: 0;
  }
  .mobile-link {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem; font-weight: 700;
    color: var(--charcoal); text-decoration: none;
    letter-spacing: -0.02em;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--border);
    display: flex; justify-content: space-between; align-items: center;
    transition: color 0.2s, padding-left 0.2s;
  }
  .mobile-link::after { content: '→'; font-size: 1rem; color: var(--accent); opacity: 0; transition: opacity 0.2s; }
  .mobile-link:hover { color: var(--accent); padding-left: 0.5rem; }
  .mobile-link:hover::after { opacity: 1; }
  .mobile-link-contact {
    margin-top: 0.5rem;
    color: var(--accent);
  }
  .mobile-divider {
    height: 0; border: none;
    margin: 0.5rem 0;
  }

  /* SECTIONS */
  section { padding: 7rem 4rem; }

  /* HERO */
  #hero {
    min-height: 100vh;
    display: grid; grid-template-columns: 1fr 1fr;
    align-items: center; gap: 4rem;
    padding-top: 10rem;
    background: var(--cream);
    position: relative; overflow: hidden;
  }
  #hero::before {
    content: '';
    position: absolute; top: -100px; right: -100px;
    width: 500px; height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(181,98,42,0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-left { position: relative; z-index: 1; }
  .hero-eyebrow {
    font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--accent); font-weight: 500; margin-bottom: 1.2rem;
    display: flex; align-items: center; gap: 0.8rem;
  }
  .hero-eyebrow::before {
    content: ''; display: block; width: 2rem; height: 1px; background: var(--accent);
  }
  .hero-name {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 900; line-height: 1.0;
    color: var(--charcoal); letter-spacing: -0.03em;
    margin-bottom: 0.4rem;
  }
  .hero-name em {
    font-style: italic; color: var(--accent);
  }
  .hero-title {
    font-size: 1rem; color: var(--muted); font-weight: 300;
    letter-spacing: 0.04em; margin-bottom: 2rem;
    border-left: 2px solid var(--accent); padding-left: 1rem;
    line-height: 1.6;
  }
  .hero-bio {
    font-size: 1rem; line-height: 1.8; color: var(--dark);
    max-width: 480px; margin-bottom: 2.5rem;
  }
  .hero-cta {
    display: flex; gap: 1rem; flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--accent); color: white;
    padding: 0.85rem 2.2rem; border-radius: 2px;
    font-size: 0.82rem; letter-spacing: 0.1em; text-transform: uppercase;
    font-weight: 500; text-decoration: none; transition: background 0.2s;
  }
  .btn-primary:hover { background: var(--dark); }
  .btn-outline {
    border: 1px solid var(--charcoal); color: var(--charcoal);
    padding: 0.85rem 2.2rem; border-radius: 2px;
    font-size: 0.82rem; letter-spacing: 0.1em; text-transform: uppercase;
    font-weight: 500; text-decoration: none; transition: all 0.2s;
  }
  .btn-outline:hover { background: var(--charcoal); color: white; }

  .hero-right {
    position: relative; display: flex;
    justify-content: center; align-items: center;
  }
  .hero-card {
    background: white;
    border: 1px solid var(--border);
    padding: 2.5rem;
    position: relative;
    box-shadow: 8px 8px 0 var(--accent);
    max-width: 360px; width: 100%;
  }
  .hero-card-label {
    font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 1rem;
  }
  .stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .stat-item { }
  .stat-number {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem; font-weight: 700; color: var(--charcoal);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.72rem; color: var(--muted); text-transform: uppercase;
    letter-spacing: 0.08em; margin-top: 0.3rem;
  }
  .hero-badge {
    position: absolute; top: -1.5rem; right: -1.5rem;
    background: var(--accent); color: white;
    width: 80px; height: 80px; border-radius: 50%;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    font-size: 0.62rem; text-align: center;
    letter-spacing: 0.05em; text-transform: uppercase;
    font-weight: 600; line-height: 1.3;
  }

  .section-link {
    color: inherit; text-decoration: none;
    border-bottom: 2px solid var(--accent);
    transition: color 0.2s;
  }
  .section-link:hover { color: var(--accent); }

  /* SECTION HEADERS */
  .section-header { margin-bottom: 4rem; }
  .section-tag {
    font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--accent); font-weight: 500; margin-bottom: 0.8rem;
    display: flex; align-items: center; gap: 0.8rem;
  }
  .section-tag::before {
    content: ''; display: block; width: 2rem; height: 1px; background: var(--accent);
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700; line-height: 1.1;
    letter-spacing: -0.02em; color: var(--charcoal);
  }
  .section-title em { font-style: italic; color: var(--accent); }

  /* ABOUT */
  #about { background: white; }
  .about-grid {
    display: grid; grid-template-columns: 1fr 1.6fr; gap: 6rem; align-items: start;
  }
  .about-aside { position: relative; top: auto; }
  .about-quote {
    font-family: 'DM Serif Display', serif;
    font-size: 1.5rem; line-height: 1.5;
    color: var(--dark); font-style: italic;
    border-left: 3px solid var(--accent);
    padding-left: 1.5rem; margin-bottom: 2rem;
  }
  .about-details { display: flex; flex-direction: column; gap: 0.8rem; }
  .about-detail-item {
    display: flex; gap: 1rem; align-items: flex-start;
    font-size: 0.88rem; color: var(--dark);
  }
  .detail-label {
    font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--muted); font-weight: 500; min-width: 80px; padding-top: 0.1rem;
  }
  .about-body p {
    font-size: 1rem; line-height: 1.9; color: var(--dark);
    margin-bottom: 1.4rem;
  }
  .interest-tags {
    display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 2rem;
  }
  .tag {
    border: 1px solid var(--border); padding: 0.4rem 1rem;
    font-size: 0.78rem; color: var(--muted); border-radius: 100px;
    letter-spacing: 0.04em;
  }

  /* WHAT I DO */
  #whatido { background: var(--cream); }
  .whatido-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;
  }
  .do-card {
    background: white; padding: 2.5rem 2rem;
    border: 1px solid var(--border);
    position: relative; overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .do-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }
  .do-card::before {
    content: ''; position: absolute; top: 0; left: 0;
    width: 3px; height: 100%; background: var(--accent);
  }
  .do-number {
    font-family: 'Playfair Display', serif;
    font-size: 3rem; font-weight: 900;
    color: var(--light-gray); line-height: 1;
    margin-bottom: 1rem;
  }
  .do-title {
    font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--accent); font-weight: 600; margin-bottom: 0.8rem;
  }
  .do-heading {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem; font-weight: 700;
    color: var(--charcoal); margin-bottom: 1rem; line-height: 1.2;
  }
  .do-list {
    list-style: none; display: flex; flex-direction: column; gap: 0.5rem;
  }
  .do-list li {
    font-size: 0.88rem; color: var(--muted);
    padding-left: 1rem; position: relative;
  }
  .do-list li::before {
    content: '→'; position: absolute; left: 0;
    color: var(--accent); font-size: 0.75rem;
  }

  /* EXPERIENCE */
  #experience { background: white; }
  .exp-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 4rem; }
  .exp-timeline { position: relative; }
  .exp-item {
    display: grid; grid-template-columns: 120px 1fr;
    gap: 2rem; margin-bottom: 3.5rem;
    padding-bottom: 3.5rem;
    border-bottom: 1px solid var(--border);
  }
  .exp-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .exp-meta { }
  .exp-date {
    font-size: 0.75rem; color: var(--muted);
    letter-spacing: 0.05em; line-height: 1.5; margin-bottom: 0.4rem;
  }
  .exp-org {
    font-size: 0.72rem; color: var(--accent); font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  .exp-role {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem; font-weight: 700;
    color: var(--charcoal); margin-bottom: 0.6rem; line-height: 1.3;
  }
  .exp-desc {
    font-size: 0.9rem; line-height: 1.7; color: var(--dark);
    margin-bottom: 0.8rem;
  }
  .exp-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .exp-tag {
    background: var(--light-gray); padding: 0.25rem 0.7rem;
    font-size: 0.7rem; color: var(--muted); border-radius: 2px;
  }

  /* PROJECTS */
  #projects { background: var(--cream); }
  .projects-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;
  }
  .project-card {
    background: white; border: 1px solid var(--border);
    padding: 2rem; position: relative;
    transition: all 0.25s;
  }
  .project-card:hover {
    border-color: var(--accent);
    box-shadow: 4px 4px 0 var(--accent);
    transform: translate(-2px, -2px);
  }
  .project-year {
    font-size: 0.72rem; color: var(--accent);
    letter-spacing: 0.12em; text-transform: uppercase;
    margin-bottom: 0.8rem; font-weight: 600;
  }
  .project-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem; font-weight: 700;
    color: var(--charcoal); margin-bottom: 0.8rem;
    line-height: 1.35;
  }
  .project-desc {
    font-size: 0.85rem; line-height: 1.7; color: var(--muted);
    margin-bottom: 1.2rem;
  }
  .project-award {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.75rem; color: var(--accent); font-weight: 600;
  }
  .project-award::before { content: '★'; }

  /* PUBLICATIONS */
  #publications { background: var(--charcoal); color: white; }
  #publications .section-title { color: white; }
  #publications .section-tag { color: var(--accent-light); }
  #publications .section-tag::before { background: var(--accent-light); }
  .pub-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 3rem; display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem; align-items: start;
    margin-top: 3rem;
  }
  .pub-journal {
    font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--accent-light); font-weight: 600; margin-bottom: 1rem;
  }
  .pub-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem; font-weight: 700; line-height: 1.3;
    color: white; margin-bottom: 1rem;
  }
  .pub-authors {
    font-size: 0.88rem; color: rgba(255,255,255,0.5);
    margin-bottom: 1.5rem; font-style: italic;
  }
  .pub-contributions { }
  .pub-contrib-label {
    font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: rgba(255,255,255,0.4); margin-bottom: 0.8rem;
  }
  .pub-contrib-list {
    list-style: none; display: flex; flex-direction: column; gap: 0.4rem;
  }
  .pub-contrib-list li {
    font-size: 0.85rem; color: rgba(255,255,255,0.7);
    padding-left: 1rem; position: relative;
  }
  .pub-contrib-list li::before {
    content: '·'; position: absolute; left: 0; color: var(--accent-light);
  }
  .pub-doi {
    display: inline-flex; align-items: center; gap: 0.5rem;
    margin-top: 1.5rem; padding: 0.7rem 1.5rem;
    border: 1px solid rgba(255,255,255,0.2); color: white;
    font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase;
    text-decoration: none; transition: all 0.2s;
  }
  .pub-doi:hover { background: var(--accent); border-color: var(--accent); }
  .pub-meta-side {
    text-align: right; min-width: 160px;
  }
  .pub-vol {
    font-family: 'Playfair Display', serif;
    font-size: 3rem; font-weight: 900; color: rgba(255,255,255,0.1);
    line-height: 1; margin-bottom: 0.5rem;
  }
  .pub-citation {
    font-size: 0.75rem; color: rgba(255,255,255,0.3);
    line-height: 1.6;
  }

  /* SKILLS */
  #skills { background: white; }
  .skills-wrapper {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem;
  }
  .skill-group { }
  .skill-group-title {
    font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--accent); font-weight: 600; margin-bottom: 1.2rem;
    padding-bottom: 0.8rem; border-bottom: 1px solid var(--border);
  }
  .skill-items { display: flex; flex-direction: column; gap: 0.6rem; }
  .skill-item {
    font-size: 0.88rem; color: var(--dark); display: flex;
    align-items: center; gap: 0.6rem;
  }
  .skill-item::before {
    content: ''; width: 5px; height: 5px; border-radius: 50%;
    background: var(--accent); flex-shrink: 0;
  }


  /* CERTIFICATIONS */
  #certifications { background: white; }
  .cert-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
  }
  .cert-card {
    border: 1px solid var(--border); padding: 1.6rem;
    background: var(--warm-white); position: relative;
    transition: border-color 0.2s, transform 0.2s;
  }
  .cert-card:hover { border-color: var(--accent); transform: translateY(-3px); }
  .cert-card::before {
    content: ''; position: absolute; top: 0; left: 0;
    width: 3px; height: 100%; background: var(--accent);
  }
  .cert-year {
    font-size: 0.68rem; color: var(--accent); font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.5rem;
  }
  .cert-title {
    font-family: 'Playfair Display', serif;
    font-size: 0.95rem; font-weight: 700;
    color: var(--charcoal); margin-bottom: 0.4rem; line-height: 1.3;
  }
  .cert-org {
    font-size: 0.78rem; color: var(--muted); margin-bottom: 0.8rem;
  }
  .cert-verify {
    font-size: 0.72rem; color: var(--accent); text-decoration: none;
    font-weight: 600; letter-spacing: 0.05em;
    transition: opacity 0.2s;
  }
  .cert-verify:hover { opacity: 0.7; }

  /* AFFILIATIONS */
  .affil-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
  }
  .affil-card {
    background: white; border: 1px solid var(--border);
    padding: 1.8rem; display: flex; gap: 1rem;
    transition: border-color 0.2s;
  }
  .affil-card:hover { border-color: var(--accent); }
  .affil-icon { font-size: 1.5rem; flex-shrink: 0; }
  .affil-title {
    font-size: 0.9rem; font-weight: 600;
    color: var(--charcoal); margin-bottom: 0.3rem; line-height: 1.3;
